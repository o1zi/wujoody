# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=https://bmsgrtjfvsvsskojglmt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose to the browser. Reset this key in Supabase if it ever leaked.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ===== App =====
# Root domain used to derive subdomains. Local dev: localhost:3000  (visit office.localhost:3000)
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
# Full origin of the platform (used in emails / redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== Salla =====
# Webhook signing secret from Salla dashboard (Settings > Webhooks)
SALLA_WEBHOOK_SECRET=your-salla-webhook-secret
# Map your Salla subscription products to plans (product id -> plan code)
# Configure plans in src/lib/plans.ts

# ===== Super admin =====
# Comma-separated emails allowed into /super-admin (must also have super_admin role).
SUPER_ADMIN_EMAILS=ziyadadmin@gmail.com

# ===== Cron (subscription expiry) =====
# Random secret; Vercel sends it as "Authorization: Bearer <CRON_SECRET>" to /api/cron/*
CRON_SECRET=generate-a-long-random-string

# ===== Email (optional, Resend) =====
# Leave empty to disable system emails. Get a key at resend.com
RESEND_API_KEY=
EMAIL_FROM=منصة المكاتب <onboarding@resend.dev>
